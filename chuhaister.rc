// Win32 resources: app icon + the version block Explorer and the Programs
// list read. Compiled with `zig rc` and linked into both executables.

#include <windows.h>

1 ICON "chuhaister.ico"

#define VER_MAJOR 0
#define VER_MINOR 1
#define VER_PATCH 1
#define VER_STR "0.1.1"

VS_VERSION_INFO VERSIONINFO
FILEVERSION    VER_MAJOR, VER_MINOR, VER_PATCH, 0
PRODUCTVERSION VER_MAJOR, VER_MINOR, VER_PATCH, 0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"   // US English, Unicode
        BEGIN
            VALUE "CompanyName",      "Bilyk Ihor"
            // Keep this ASCII-only: the resource compiler reads the file in a
            // codepage, so an em dash here lands in Explorer as mojibake.
            VALUE "FileDescription",  "chuhAIster - Claude Code account switcher"
            VALUE "FileVersion",      VER_STR
            VALUE "InternalName",     "chuhaister"
            VALUE "LegalCopyright",   "Bilyk Ihor - MIT License"
            VALUE "OriginalFilename", "chuhaister-tray.exe"
            VALUE "ProductName",      "chuhAIster"
            VALUE "ProductVersion",   VER_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
